  "type": "module",
  "main": "dist/index.js",
  "devDependencies": {
    "@types/node": "^22.10.10",
    "esbuild": "^0.24.2",
    "inquirer": "^12.3.2"
  },
  "dependencies": {
    "fs-extra": "^11.3.0",
    "ora": "^8.1.1"
  }
}
